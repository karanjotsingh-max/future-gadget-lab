# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing ─────────────────────────────────────
/coverage
.nyc_output/

# ─── Next.js / build output ──────────────────────
/.next/
/out/
/build
/dist

# ─── Environment files (NEVER commit) ────────────
.env*
!.env.example

# ─── Logs ────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Editor / OS junk ────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.pem

# ─── TypeScript ──────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ──────────────────────────────────────
.vercel

# ─── Supabase local dev ──────────────────────────
supabase/.branches
supabase/.temp

# ─── Misc ────────────────────────────────────────
*.local
.cache/

# ─── Sprite assets — downloaded locally, never committed ────────────
# Place CRS_J*.png files (renamed) here: public/sprites/
# Run: node scripts/rename-sprites.mjs <path-to-downloaded-drive-folder>
public/sprites/*.png
public/sprites/*.gif
public/sprites/*.wav
public/sprites/_nul

# ─── Personal tracking files (not for public repo) ─
build-tracking-doc.ps1
Steins-Gate-Project-Tracking.docx
*.docx

# ─── Cursor / AI agent artifacts ─────────────────
# One-off post/brief docs — personal, not for public repo
LINKEDIN_POST_BRIEF.md
# Cursor runtime noise (transcripts, terminal snapshots, MCP cache)
# Skills and rules inside .cursor/ ARE committed — only runtime dirs ignored
.cursor/agent-transcripts/
.cursor/terminals/
.cursor/mcps/

