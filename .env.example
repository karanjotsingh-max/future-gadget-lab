# Future Gadget Lab — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` (it is gitignored).

# ─────────────────────────────────────────────────────────────
# Gemini (LLM provider via Google AI Studio) — server only
# Free tier: 1 M tokens/day (10x Groq free tier)
# Get a free key: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase — auth, database, pgvector
# Create a project: https://supabase.com
# Settings → API → copy URL, anon key, and service_role key
# ─────────────────────────────────────────────────────────────

# Safe to expose in the browser (used by the public client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY — bypasses Row Level Security. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# Optional — set in production only
# ─────────────────────────────────────────────────────────────

# Public site URL (used for auth redirects, share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
